<section id="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1>Hi, I'm<br /><em>Tina Ohanian.</em></h1>
      <p class="hero-desc">
        I'm a presentation designer focused on pitch decks, visual storytelling,
        and branded sales materials within sports and entertainment. I help
        organizations translate ideas and concepts into polished, executive-ready
        presentations.
      </p>
      <a href="#work" class="hero-cta">View my work →</a>
    </div>
    <div class="hero-photo-wrap">
      <img
        src="/images/tina.jpg"
        alt="Tina Ohanian"
        class="hero-photo"
        onerror="this.outerHTML='<div class=\'hero-photo-placeholder\'>Add images/tina.jpg</div>'"
      />
    </div>
  </div>
</section>
