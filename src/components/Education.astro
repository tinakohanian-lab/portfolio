<section id="education" class="section">
  <div class="inner">
    <div class="section-header">
      <h2 class="section-title"><em>Education</em></h2>
      <span class="section-count">05 credentials</span>
    </div>
    <div class="edu-grid">
      <div class="edu-intro">
        <p>
          Academic background combining financial analysis and digital marketing —
          bringing both creative and analytical perspectives to every project.
          Studies emphasized brand strategy, consumer behavior, and visual
          communication.
        </p>
        <div style="margin-top: 40px;">
          <p
            class="about-block-label"
            style="font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-lo);margin-bottom:16px;"
          >
            Awards &amp; Honors
          </p>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div
              style="display:flex;align-items:center;gap:10px;font-size:13px;color:var(--ink);border-bottom:1px solid var(--border);padding-bottom:14px;"
            >
              <img
                class="lb-trigger"
                src="/images/award-deans-list.png"
                alt="Dean's List Award"
                style="width:48px;height:48px;object-fit:cover;border-radius:4px;flex-shrink:0;cursor:zoom-in;"
              />
              <span>Dean's List Award — click to view</span>
            </div>
            <div style="display:flex;align-items:center;gap:10px;font-size:13px;color:var(--ink);">
              <img
                class="lb-trigger"
                src="/images/award-senator.png"
                alt="GCC Senator of Activities Award"
                style="width:48px;height:48px;object-fit:cover;border-radius:4px;flex-shrink:0;cursor:zoom-in;"
              />
              <span>GCC Senator of Activities — click to view</span>
            </div>
          </div>
        </div>
      </div>
      <ul class="edu-items">
        <li class="edu-item">
          <p class="edu-degree">Associate of Arts — General Studies</p>
          <p class="edu-school">Glendale Community College &nbsp;·&nbsp; 2019 – 2021</p>
          <p class="edu-detail">
            Senator of Activities — ASGCC Associated Students of Glendale Community
            College
          </p>
        </li>
        <li class="edu-item">
          <p class="edu-degree">
            Bachelor of Science — Business Administration, Marketing
          </p>
          <p class="edu-school">California State University, Northridge</p>
          <p class="edu-detail">
            Focus: Digital Marketing, Brand Strategy, Visual Communications
            &nbsp;·&nbsp; Dean's List &nbsp;·&nbsp; Magna Cum Laude
          </p>
          <div style="display:flex;align-items:center;gap:8px;margin-top:10px;">
            <img
              class="lb-trigger"
              src="/images/degree-marketing.png"
              alt="B.S. Marketing Degree"
              style="width:40px;height:40px;object-fit:cover;border-radius:3px;border:1px solid var(--border);cursor:zoom-in;flex-shrink:0;"
            />
            <span style="font-size:12px;color:var(--ink-lo);">Click to view degree</span>
          </div>
        </li>
        <li class="edu-item">
          <p class="edu-degree">
            Bachelor of Science — Business Administration, Financial Analysis
          </p>
          <p class="edu-school">California State University, Northridge</p>
          <p class="edu-detail">
            Focus: Data Analysis, Forecasting, Business Strategy &nbsp;·&nbsp;
            Dean's List &nbsp;·&nbsp; Magna Cum Laude
          </p>
          <div style="display:flex;align-items:center;gap:8px;margin-top:10px;">
            <img
              class="lb-trigger"
              src="/images/degree-financial.png"
              alt="B.S. Financial Analysis Degree"
              style="width:40px;height:40px;object-fit:cover;border-radius:3px;border:1px solid var(--border);cursor:zoom-in;flex-shrink:0;"
            />
            <span style="font-size:12px;color:var(--ink-lo);">Click to view degree</span>
          </div>
        </li>
        <li class="edu-item">
          <p class="edu-degree">
            Master of Business Administration (MBA) — In Progress
          </p>
          <p class="edu-school">California State University, Northridge</p>
          <p class="edu-detail">
            Expected Completion: May 2028 &nbsp;·&nbsp; Emphasis: Strategic
            Management &amp; Design
          </p>
        </li>
        <li class="edu-item">
          <p class="edu-degree">Adobe Photoshop for Design &amp; Visual Media</p>
          <p class="edu-school">California State University, Northridge</p>
          <p class="edu-detail">
            Photo compositing, color correction, layer masking, typography
            integration, and preparing digital assets for print and presentation
            use.
          </p>
        </li>
      </ul>
    </div>
  </div>
</section>
